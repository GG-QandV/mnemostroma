{
  "manifest_version": 3,
  "name": "Mnemostroma",
  "version": "1.0.4",
  "description": "Captures AI chat sessions into local Mnemostroma memory daemon.",

  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:8766/*",
    "http://localhost:8766/*"
  ],

  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://perplexity.ai/*",
        "https://gemini.google.com/*",
        "https://deepseek.com/*",
        "https://grok.com/*"
      ],
      "js": ["src/content/bridge.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "src/content/index.js",
        "src/content/adapters/*.js",
        "src/shared/*.js"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://perplexity.ai/*",
        "https://gemini.google.com/*",
        "https://deepseek.com/*",
        "https://grok.com/*"
      ]
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "assets/icon-16.png",
      "48":  "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "mnemostroma@mnemostroma.ai",
      "strict_min_version": "109.0"
    }
  }
}
